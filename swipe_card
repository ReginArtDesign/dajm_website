import * as React from "react"
import { useState, useEffect, useRef } from "react"
import {
    motion,
    useMotionValue,
    useSpring,
    useTransform,
    AnimatePresence,
    PanInfo,
} from "framer-motion"
import { addPropertyControls, ControlType } from "framer"

interface PatternTiltCardProps {
    title: string
    category: string
    shortDescription: string
    expandedContent: string
    badgeText: string
    borderRadius: number
    patternImage: string
    accentColor: string
    titleFontFamily: string
    categoryFontFamily: string
    badgeFontFamily: string
    shortDescFontFamily: string
    expandedDescFontFamily: string
    uiFontFamily: string
}

export default function PatternTiltCard({
    title = "UI/UX & Branding",
    category = "PRECISION & PUNK",
    shortDescription = "Emberközpontú és akadálymentes design, mikroszintű pontossággal és egy csipetnyi lázadással.",
    expandedContent = "Komponensalapú Design Systemek, design tokenek, WCAG AA megfelelőség és 60+ FPS-re optimalizált interakciók tervezése Figma-ban és Framerben.",
    badgeText = "SZENIOR",
    borderRadius = 24,
    patternImage = "",
    accentColor = "#FF2A85",
    titleFontFamily = "'Montserrat', sans-serif",
    categoryFontFamily = "'Space Grotesk', sans-serif",
    badgeFontFamily = "'Inter', sans-serif",
    shortDescFontFamily = "'Inter', sans-serif",
    expandedDescFontFamily = "'Inter', sans-serif",
    uiFontFamily = "'Inter', sans-serif",
}: PatternTiltCardProps) {
    const [isExpanded, setIsExpanded] = useState(false)
    const [isHovered, setIsHovered] = useState(false)
    const [isTouchActive, setIsTouchActive] = useState(false)
    const [isMobile, setIsMobile] = useState(false)
    const leaveTimeoutRef = useRef<NodeJS.Timeout | null>(null)

    useEffect(() => {
        const handleResize = () => {
            if (typeof window !== "undefined")
                setIsMobile(window.innerWidth < 768)
        }
        handleResize()
        window.addEventListener("resize", handleResize)
        return () => window.removeEventListener("resize", handleResize)
    }, [])

    const mouseX = useMotionValue(0)
    const mouseY = useMotionValue(0)

    const springConfig = { stiffness: 65, damping: 18, mass: 0.6 }
    const rotateX = useSpring(
        useTransform(mouseY, [-0.5, 0.5], [10, -10]),
        springConfig
    )
    const rotateY = useSpring(
        useTransform(mouseX, [-0.5, 0.5], [-10, 10]),
        springConfig
    )

    const sheenX = useSpring(
        useTransform(mouseX, [-0.5, 0.5], ["-80%", "80%"]),
        springConfig
    )
    const sheenY = useSpring(
        useTransform(mouseY, [-0.5, 0.5], ["-30%", "30%"]),
        springConfig
    )

    const isPatternActive = isHovered || isTouchActive

    const handleMouseMove = (e: React.MouseEvent<HTMLDivElement>) => {
        if (isMobile) return
        if (leaveTimeoutRef.current) clearTimeout(leaveTimeoutRef.current)

        const rect = e.currentTarget.getBoundingClientRect()
        mouseX.set((e.clientX - rect.left) / rect.width - 0.5)
        mouseY.set((e.clientY - rect.top) / rect.height - 0.5)
    }

    const handleMouseEnter = () => {
        if (isMobile) return
        if (leaveTimeoutRef.current) clearTimeout(leaveTimeoutRef.current)
        setIsHovered(true)
    }

    const handleMouseLeave = () => {
        if (isMobile) return
        leaveTimeoutRef.current = setTimeout(() => {
            setIsHovered(false)
            mouseX.set(0)
            mouseY.set(0)
        }, 350)
    }

    const handleDragStart = () => {
        setIsTouchActive(true)
    }

    const handleDragEnd = (
        _event: MouseEvent | TouchEvent | PointerEvent,
        info: PanInfo
    ) => {
        setIsTouchActive(false)
        const threshold = 15
        const velocityThreshold = 180

        if (info.offset.y > threshold || info.velocity.y > velocityThreshold) {
            setIsExpanded(true)
        } else if (
            info.offset.y < -threshold ||
            info.velocity.y < -velocityThreshold
        ) {
            setIsExpanded(false)
        }
    }

    return (
        <div style={styles.container}>
            <motion.div
                style={{
                    ...styles.tiltWrapper,
                    rotateX: isMobile ? 0 : rotateX,
                    rotateY: isMobile ? 0 : rotateY,
                    borderRadius: `${borderRadius}px`,
                    transformStyle: "preserve-3d",
                    zIndex: isHovered || isExpanded || isTouchActive ? 50 : 1,
                }}
                onMouseMove={handleMouseMove}
                onMouseEnter={handleMouseEnter}
                onMouseLeave={handleMouseLeave}
            >
                {/* --- HÁTSÓ LEOPÁRD MINTA KERET --- */}
                <motion.div
                    animate={{
                        opacity: isPatternActive ? 1 : 0,
                        scaleX: isPatternActive
                            ? isMobile
                                ? 1.08
                                : 1.07
                            : 0.94,
                        scaleY: isPatternActive
                            ? isMobile
                                ? 1.06
                                : 1.06
                            : 0.94,
                        rotateZ: isPatternActive ? 1.5 : 0,
                    }}
                    transition={{
                        type: "spring",
                        stiffness: 350,
                        damping: 25,
                    }}
                    style={{
                        ...styles.patternBacking,
                        borderRadius: `${borderRadius + 4}px`,
                        backgroundImage: patternImage
                            ? `url(${patternImage})`
                            : "linear-gradient(135deg, #FF2A85 0%, #00F2FE 50%, #7928CA 100%)",
                        backgroundSize: "cover",
                        backgroundPosition: "center",
                        transform: "translateZ(-14px)",
                        boxShadow: isPatternActive
                            ? "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
                            : "none",
                    }}
                    aria-hidden="true"
                />

                {/* --- ELÜLSŐ ÜVEG KÁRTYA --- */}
                <div
                    style={{
                        ...styles.glassCard,
                        borderRadius: `${borderRadius}px`,
                        transform: "translateZ(0px)",
                    }}
                >
                    {!isMobile && (
                        <motion.div
                            style={{
                                ...styles.sheen,
                                x: sheenX,
                                y: sheenY,
                            }}
                            aria-hidden="true"
                        />
                    )}

                    <div style={styles.contentContainer}>
                        <div style={styles.header}>
                            <div style={styles.categoryBadge}>
                                <span
                                    style={{
                                        ...styles.categoryText,
                                        fontFamily: categoryFontFamily,
                                    }}
                                >
                                    {category}
                                </span>
                            </div>
                            <span
                                style={{
                                    ...styles.badgeText,
                                    fontFamily: badgeFontFamily,
                                }}
                            >
                                {badgeText}
                            </span>
                        </div>

                        <h3
                            style={{
                                ...styles.title,
                                fontFamily: titleFontFamily,
                            }}
                        >
                            {title}
                        </h3>
                        <p
                            style={{
                                ...styles.shortDescription,
                                fontFamily: shortDescFontFamily,
                            }}
                        >
                            {shortDescription}
                        </p>

                        {/* DESKTOP TOGGLE GOMB (KÉZZEL RAJZOLT NYÍLLAL) */}
                        {!isMobile && (
                            <div style={styles.desktopToggleWrapper}>
                                <motion.button
                                    onClick={() => setIsExpanded(!isExpanded)}
                                    style={{
                                        ...styles.desktopToggleButton,
                                        fontFamily: uiFontFamily,
                                    }}
                                    whileHover={{ scale: 1.03 }}
                                    whileTap={{ scale: 0.97 }}
                                    aria-expanded={isExpanded}
                                >
                                    <span style={styles.toggleText}>
                                        {isExpanded
                                            ? "Kevesebb infó"
                                            : "További infó"}
                                    </span>

                                    {/* KÉZZEL RAJZOLT SVG NYÍL ANIMÁCIÓ */}
                                    <motion.div
                                        style={styles.arrowIconWrapper}
                                        animate={{
                                            rotate: isExpanded ? -180 : 0,
                                        }}
                                        transition={{
                                            type: "spring",
                                            stiffness: 200,
                                            damping: 18,
                                        }}
                                    >
                                        <svg
                                            width="18"
                                            height="18"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                        >
                                            {/* Kézzel rajzolt, enyhén hullámos szár és egyenetlen nyílhegy */}
                                            <path
                                                d="M11.5 3.5 C11.2 8, 12.3 13, 11.8 20.5 M6 14.5 C8.2 16.5, 10.1 18.8, 11.8 20.5 C13.2 18.5, 15.1 16.2, 17.8 14.2"
                                                stroke={accentColor}
                                                strokeWidth="2.5"
                                                strokeLinecap="round"
                                                strokeLinejoin="round"
                                            />
                                        </svg>
                                    </motion.div>
                                </motion.button>
                            </div>
                        )}

                        {/* LENYÍLÓ TARTALOM */}
                        <AnimatePresence initial={false}>
                            {isExpanded && (
                                <motion.div
                                    initial={{ opacity: 0, height: 0 }}
                                    animate={{ opacity: 1, height: "auto" }}
                                    exit={{ opacity: 0, height: 0 }}
                                    transition={{
                                        duration: 0.35,
                                        ease: [0.16, 1, 0.3, 1],
                                    }}
                                    style={styles.expandedWrapper}
                                >
                                    <div style={styles.expandedInner}>
                                        <div
                                            style={{
                                                ...styles.divider,
                                                background: `linear-gradient(90deg, ${accentColor}80 0%, rgba(17,17,17,0.1) 100%)`,
                                            }}
                                        />
                                        <p
                                            style={{
                                                ...styles.expandedText,
                                                fontFamily:
                                                    expandedDescFontFamily,
                                            }}
                                        >
                                            {expandedContent}
                                        </p>
                                    </div>
                                </motion.div>
                            )}
                        </AnimatePresence>

                        {/* MOBIL DRAG HANDLE */}
                        {isMobile && (
                            <motion.div
                                style={styles.mobileHandleContainer}
                                drag="y"
                                dragConstraints={{ top: -8, bottom: 8 }}
                                dragElastic={0.06}
                                onDragStart={handleDragStart}
                                onDragEnd={handleDragEnd}
                                whileTap={{ scale: 0.96 }}
                            >
                                <div
                                    style={styles.mobileHandleBar}
                                    aria-hidden="true"
                                />
                                <span
                                    style={{
                                        ...styles.mobileHandleLabel,
                                        fontFamily: uiFontFamily,
                                    }}
                                >
                                    {isExpanded
                                        ? "Húzd fel a bezáráshoz ↑"
                                        : "Húzd le a részletekért ↓"}
                                </span>
                            </motion.div>
                        )}
                    </div>
                </div>
            </motion.div>
        </div>
    )
}

